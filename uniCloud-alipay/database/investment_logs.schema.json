{
  "bsonType": "object",
  "required": [
    "user_id",
    "holding_id",
    "account_id",
    "action",
    "amount",
    "market_value_after",
    "created_at"
  ],
  "permission": {
    "read": "doc.user_id == auth.uid",
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "PK"
    },
    "user_id": {
      "bsonType": "string",
      "description": "FK→users.user_id",
      "maxLength": 64,
      "foreignKey": "users.user_id"
    },
    "holding_id": {
      "bsonType": "string",
      "description": "FK→investment_holdings._id",
      "foreignKey": "investment_holdings._id"
    },
    "account_id": {
      "bsonType": "string",
      "description": "FK→asset_accounts._id",
      "foreignKey": "asset_accounts._id"
    },
    "action": {
      "bsonType": "string",
      "enum": [
        "buy",
        "sell",
        "dividend",
        "adjust",
        "dca"
      ],
      "description": "操作"
    },
    "amount": {
      "bsonType": "int",
      "description": "金额(分)",
      "minimum": 0
    },
    "shares_delta": {
      "bsonType": "double",
      "description": "份额变动"
    },
    "market_value_after": {
      "bsonType": "int",
      "description": "变动后市值(分)",
      "minimum": 0
    },
    "source_account_id": {
      "bsonType": "string",
      "description": "FK→asset_accounts._id",
      "foreignKey": "asset_accounts._id"
    },
    "target_account_id": {
      "bsonType": "string",
      "description": "FK→asset_accounts._id",
      "foreignKey": "asset_accounts._id"
    },
    "transaction_id": {
      "bsonType": "string",
      "description": "FK→transactions._id",
      "foreignKey": "transactions._id"
    },
    "note": {
      "bsonType": "string",
      "description": "备注",
      "maxLength": 200,
      "defaultValue": ""
    },
    "created_at": {
      "bsonType": "timestamp",
      "description": "创建时间"
    }
  }
}
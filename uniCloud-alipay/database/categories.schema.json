{
  "bsonType": "object",
  "required": [
    "user_id",
    "type",
    "name",
    "created_at"
  ],
  "permission": {
    "read": "doc.user_id == auth.uid",
    "create": "doc.user_id == auth.uid",
    "update": "doc.user_id == auth.uid",
    "delete": "doc.user_id == auth.uid"
  },
  "properties": {
    "_id": {
      "description": "PK"
    },
    "user_id": {
      "bsonType": "string",
      "description": "FK→users.user_id",
      "maxLength": 64,
      "foreignKey": "users.user_id"
    },
    "type": {
      "bsonType": "string",
      "enum": [
        "expense",
        "income"
      ],
      "description": "分类类型"
    },
    "name": {
      "bsonType": "string",
      "description": "分类名",
      "maxLength": 32
    },
    "icon": {
      "bsonType": "string",
      "description": "图标",
      "maxLength": 64,
      "defaultValue": "📦"
    },
    "is_system": {
      "bsonType": "bool",
      "description": "系统预置",
      "defaultValue": false
    },
    "is_hidden": {
      "bsonType": "bool",
      "description": "隐藏",
      "defaultValue": false
    },
    "sort_order": {
      "bsonType": "int",
      "description": "排序",
      "defaultValue": 0
    },
    "merged_to_id": {
      "bsonType": "string",
      "description": "FK→categories._id",
      "foreignKey": "categories._id"
    },
    "created_at": {
      "bsonType": "timestamp",
      "description": "创建时间"
    }
  }
}
{
  "bsonType": "object",
  "required": [
    "user_id",
    "account_id",
    "name",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": "doc.user_id == auth.uid",
    "create": "doc.user_id == auth.uid",
    "update": "doc.user_id == auth.uid",
    "delete": "doc.user_id == auth.uid"
  },
  "properties": {
    "_id": {
      "description": "PK"
    },
    "user_id": {
      "bsonType": "string",
      "description": "FK→users.user_id",
      "maxLength": 64,
      "foreignKey": "users.user_id"
    },
    "account_id": {
      "bsonType": "string",
      "description": "FK→asset_accounts._id",
      "foreignKey": "asset_accounts._id"
    },
    "name": {
      "bsonType": "string",
      "description": "名称",
      "maxLength": 64
    },
    "code": {
      "bsonType": "string",
      "description": "代码",
      "maxLength": 32
    },
    "asset_type": {
      "bsonType": "string",
      "enum": [
        "fund",
        "stock",
        "bond",
        "gold",
        "wealth",
        "other"
      ],
      "description": "品种",
      "defaultValue": "fund"
    },
    "shares": {
      "bsonType": "double",
      "description": "份额",
      "minimum": 0,
      "defaultValue": 0
    },
    "unit_price": {
      "bsonType": "int",
      "description": "单价(分)"
    },
    "market_value": {
      "bsonType": "int",
      "description": "市值(分)",
      "minimum": 0,
      "defaultValue": 0
    },
    "cost_basis": {
      "bsonType": "int",
      "description": "成本(分)",
      "minimum": 0
    },
    "profit_loss": {
      "bsonType": "int",
      "description": "浮动盈亏(分)"
    },
    "last_adjust_at": {
      "bsonType": "timestamp",
      "description": "最近调整"
    },
    "deleted_at": {
      "bsonType": "timestamp",
      "description": "软删"
    },
    "created_at": {
      "bsonType": "timestamp",
      "description": "创建时间"
    },
    "updated_at": {
      "bsonType": "timestamp",
      "description": "更新时间"
    }
  }
}
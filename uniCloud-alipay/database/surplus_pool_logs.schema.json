{
  "bsonType": "object",
  "required": [
    "user_id",
    "direction",
    "amount",
    "balance_after",
    "reason",
    "created_at"
  ],
  "permission": {
    "read": "doc.user_id == auth.uid",
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "PK"
    },
    "user_id": {
      "bsonType": "string",
      "description": "FK→users.user_id",
      "maxLength": 64,
      "foreignKey": "users.user_id"
    },
    "direction": {
      "bsonType": "string",
      "enum": [
        "in",
        "out"
      ],
      "description": "方向"
    },
    "amount": {
      "bsonType": "int",
      "description": "变动额(分)",
      "minimum": 1
    },
    "balance_after": {
      "bsonType": "int",
      "description": "变动后余额(分)",
      "minimum": 0
    },
    "reason": {
      "bsonType": "string",
      "enum": [
        "daily_surplus",
        "wish_return",
        "savings_return",
        "consume_deduct",
        "allocation_out",
        "manual_adjust"
      ],
      "description": "原因"
    },
    "ref_type": {
      "bsonType": "string",
      "enum": [
        "settlement",
        "wish",
        "savings",
        "transaction",
        "allocation"
      ],
      "description": "关联类型"
    },
    "ref_id": {
      "bsonType": "string",
      "description": "关联 ID"
    },
    "date_key": {
      "bsonType": "string",
      "description": "关联日",
      "maxLength": 10
    },
    "note": {
      "bsonType": "string",
      "description": "备注",
      "maxLength": 200,
      "defaultValue": ""
    },
    "created_at": {
      "bsonType": "timestamp",
      "description": "创建时间"
    }
  }
}